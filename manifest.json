{
  "manifest_version": 3,
  "name": "知乎文章下载器",
  "description": "将知乎文章、回答、问题、想法导出为 Markdown 文件",
  "version": "1.0.0",
  "permissions": ["activeTab"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.zhihu.com/*",
        "https://zhuanlan.zhihu.com/*"
      ],
      "js": ["content/detector.js"],
      "run_at": "document_idle"
    }
  ]
}
